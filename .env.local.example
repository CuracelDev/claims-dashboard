# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_WEBHOOK_HEALTHOPS=https://hooks.slack.com/services/YOUR/WEBHOOK/HERE

# AI - Azure OpenAI (primary)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Models deployed: gpt-4.1 (complex tasks), gpt-4.1-mini (lighter tasks)

# AI - Anthropic Claude (fallback/reference)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Optional: OpenAI (alternative)
# OPENAI_API_KEY=sk-your-openai-key
# AI_PROVIDER=azure  # Options: azure (default), anthropic, openai

# Metabase (Health database)
METABASE_URL=https://your-metabase-instance.awsapprunner.com
METABASE_USERNAME=your-email@company.com
METABASE_PASSWORD=your-metabase-password
